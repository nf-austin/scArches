manifest {
  name            = 'nf-austin/'
  author          = 'Austin Varela'
  homePage        = 'https://github.com/nf-austin/scArches'
  description     = 'Automated scArches-based integration and label transfer.'
  mainScript      = 'main.nf'
  nextflowVersion = '>=24.04.0'
  version         = '1.0.0'
  defaultBranch   = 'main'
}

params {
  // Input/Output
  h5ad_dir = "data/*.h5ad"
  outdir   = "results"

  // Training options
  train_model = true
  model_type  = "SCANVI"  // SCVI,SCANVI,SCPOLI
  model_name  = "model"   // Must match between the run that trains the model and any later
                          // --train_model false run reusing "${outdir}/${model_name}.tar.gz"
  train_h5ad  = ""        // Reference dataset to train on; required when --train_model true
  dataset_obs = ""        // obs column identifying batches/datasets; blank = treat as one batch
  celltype_obs = "cell_type"  // obs column with reference cell type labels

  n_hvgs               = 3000  // number of highly variable genes used for training
  train_max_epochs     = 400   // max epochs for TRAIN_MODEL
  finetune_epochs      = 20    // SCANVI fine-tuning epochs after the SCVI pretraining stage
  integrate_max_epochs = 200   // max epochs for APPLY_MODEL's query mapping

  use_gpu = false  // train/apply on GPU instead of CPU; requires a CUDA-capable executor/container runtime

  // Resource caps
  max_memory = 128.GB
  max_cpus   = 32
  max_time   = 72.h
}

process {
  resourceLimits = [
    memory: params.max_memory,
    cpus  : params.max_cpus,
    time  : params.max_time
  ]

  withName: 'TRAIN_MODEL' {
    cpus          = { 16 * task.attempt }
    memory        = { 64.GB * task.attempt }
    time          = { 24.h * task.attempt }
    errorStrategy = 'retry'
    maxRetries    = 2
    accelerator   = params.use_gpu ? 1 : 0  // requested by cluster/cloud executors (k8s, AWS Batch, Slurm, ...); ignored locally
  }

  withName: 'APPLY_MODEL' {
    cpus          = { 8 * task.attempt }
    memory        = { 32.GB * task.attempt }
    time          = { 6.h * task.attempt }
    errorStrategy = 'retry'
    maxRetries    = 2
    accelerator   = params.use_gpu ? 1 : 0
  }

  withName: 'MAKE_REPORT|CONCAT_H5ADS|COMPRESS|DECOMPRESS' {
    cpus          = { 4 * task.attempt }
    memory        = { 16.GB * task.attempt }
    time          = { 2.h * task.attempt }
    errorStrategy = 'retry'
    maxRetries    = 2
  }
}

profiles {
  docker {
    docker.enabled       = true
    docker.userEmulation = true
    docker.runOptions    = params.use_gpu ? '--gpus all' : ''
    singularity.enabled  = false
    conda.enabled        = true
  }
  singularity {
    singularity.enabled    = true
    singularity.autoMounts = true
    singularity.runOptions = params.use_gpu ? '--nv' : ''
    docker.enabled          = false
    conda.enabled           = true
  }
  conda {
    conda.enabled       = true
    docker.enabled      = false
    singularity.enabled = false
  }
}
